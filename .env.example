# git-gud-samaritans Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# GitHub Personal Access Token
# Required scopes: repo, read:org, read:user
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to your nexus-agents installation (optional - only needed for direct integration)
# If using MCP server mode, nexus-agents should be in your PATH
NEXUS_AGENTS_PATH=${HOME}/git/nexus-agents

# =============================================================================
# Optional Configuration
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log format (json, text)
LOG_FORMAT=text

# =============================================================================
# Discovery Settings
# =============================================================================

# Languages to target (comma-separated)
TARGET_LANGUAGES=python,javascript,typescript,rust,go

# Minimum stars for a repo to be considered
MIN_STARS=10

# Maximum open issues (avoid overwhelming projects)
MAX_OPEN_ISSUES=500

# Minimum maintainer activity (days since last commit)
MAX_DAYS_SINCE_COMMIT=90

# Labels to search for (comma-separated)
TARGET_LABELS=good first issue,help wanted,hacktoberfest,beginner friendly

# =============================================================================
# Triage Settings
# =============================================================================

# Minimum score for an issue to be considered (0-100)
MIN_TRIAGE_SCORE=60

# Maximum estimated complexity (low, medium, high)
MAX_COMPLEXITY=medium

# Require existing tests in the repo
REQUIRE_TESTS=true

# =============================================================================
# Contribution Settings
# =============================================================================

# Maximum PRs to submit per day (be a good citizen)
MAX_DAILY_PRS=5

# Dry run mode (don't actually submit PRs)
DRY_RUN=false

# Fork repos before contributing (recommended)
USE_FORKS=true

# Branch naming prefix
BRANCH_PREFIX=ggs

# =============================================================================
# MCP Settings
# =============================================================================

# MCP server port
MCP_PORT=3000

# Enable MCP debug logging
MCP_DEBUG=false

# =============================================================================
# Metrics & Reporting
# =============================================================================

# Enable metrics collection
METRICS_ENABLED=true

# Metrics storage path
METRICS_PATH=./data/metrics.db

# =============================================================================
# Rate Limiting
# =============================================================================

# GitHub API rate limit buffer (keep this many requests in reserve)
GITHUB_RATE_LIMIT_BUFFER=100

# Delay between API calls (seconds)
API_CALL_DELAY=0.5

# =============================================================================
# Advanced / Experimental
# =============================================================================

# Enable experimental features
EXPERIMENTAL_FEATURES=false

# Custom user agent for API calls
USER_AGENT=git-gud-samaritans/0.1.0
